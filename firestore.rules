rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'hon.mom.is@gmail.com' || 
        request.auth.token.email == 'hon.mom.edu@gmail.com' ||
        request.auth.token.email == 'admin@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUserConfig(data) {
      return data.email is string && data.email.size() <= 200 &&
             data.name is string && data.name.size() <= 200 &&
             (!data.keys().hasAny(['photoURL']) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!data.keys().hasAny(['isApproved']) || data.isApproved is bool) &&
             (!data.keys().hasAny(['approverCode']) || (data.approverCode is string && data.approverCode.size() <= 100)) &&
             (!data.keys().hasAny(['lastLogin']) || data.lastLogin == request.time);
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && isValidUserConfig(incoming()) && (
        !incoming().keys().hasAny(['isApproved']) || 
        (incoming().isApproved == true && exists(/databases/$(database)/documents/secrets/$(incoming().approverCode))) ||
        isAdmin()
      );
      
      allow update: if isOwner(userId) && isValidUserConfig(incoming()) && (
        isAdmin() ||
        (
          !incoming().diff(existing()).affectedKeys().hasAny(['isApproved']) ||
          (incoming().isApproved == true && exists(/databases/$(database)/documents/secrets/$(incoming().approverCode)))
        )
      );

      allow delete: if isAdmin();
    }

    match /secrets/{secretId} {
      // Users can only GET if they know the ID (this is the key to our golden code logic)
      allow get: if isSignedIn();
      // Only admins can list all secrets or write to them
      allow list: if isAdmin();
      
      allow create: if (isAdmin() || (isSignedIn() && incoming().isAutoGenerated == true)) &&
        incoming().createdBy is string &&
        incoming().createdBy.size() <= 100 &&
        incoming().isActive is bool;

      allow update: if (isAdmin() && incoming().isActive is bool) ||
        (isSignedIn() && existing().isActive == true && incoming().isActive == false && incoming().usedBy == request.auth.token.email && incoming().diff(existing()).affectedKeys().hasOnly(['isActive', 'usedBy', 'usedAt']));
        
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn(); // Need to read to check isAdmin
      allow write: if isAdmin();
    }
  }
}
